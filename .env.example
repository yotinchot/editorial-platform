# Copy to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ── Database ────────────────────────────────────────────────────────────────
# Pooled connection — used by the app at runtime (db/client.ts).
# On Vercel Postgres: copy the "Pooled connection" string from the Storage tab.
POSTGRES_URL=postgres://user:password@host:5432/dbname?sslmode=require

# Direct (non-pooled) connection — used only for DDL migrations (db:migrate).
# On Vercel Postgres: copy the "Direct connection" string from the Storage tab.
# Leave blank if you are not running migrations locally.
POSTGRES_URL_NON_POOLING=postgres://user:password@host:5432/dbname?sslmode=require

# ── Site metadata ────────────────────────────────────────────────────────────
# Production URL — no trailing slash.
# Used for: canonical URLs, sitemap, Open Graph og:url, JSON-LD WebSite.
# Must be set correctly before going live — wrong value breaks SEO.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Author name shown in BlogPosting JSON-LD and Open Graph metadata.
# Should be a real person's name, not the site name.
NEXT_PUBLIC_AUTHOR_NAME=Your Name

# ── Admin auth ──────────────────────────────────────────────────────────────
ADMIN_PASSWORD=change-me-before-first-login

# ── Cloudinary (image uploads) ───────────────────────────────────────────────
# Create a free account at https://cloudinary.com
# Settings → API Keys → Copy Cloud Name, API Key, API Secret
CLOUDINARY_CLOUD_NAME=        # e.g. my-cloud
CLOUDINARY_API_KEY=           # numeric, e.g. 123456789012345
CLOUDINARY_API_SECRET=        # secret — NEVER expose to the client
