# =============================================================================
# Editorial Platform — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development.
# Never commit .env.local or any file containing real credentials.
# All variables are server-side only unless prefixed with NEXT_PUBLIC_.
# =============================================================================


# -----------------------------------------------------------------------------
# Database — Vercel Postgres
# All four URLs are provided automatically when you add a Vercel Postgres
# database to your project (Project → Storage → Postgres → .env.local tab).
# -----------------------------------------------------------------------------

# Pooled connection (used by Drizzle ORM at runtime)
DATABASE_URL=

# Vercel Postgres pooled URL (same as DATABASE_URL in most setups)
POSTGRES_URL=

# Prisma-compatible pooled URL (provided by Vercel; useful if tooling expects it)
POSTGRES_PRISMA_URL=

# Direct (non-pooled) connection — required for migrations and Drizzle Studio
POSTGRES_URL_NON_POOLING=

# Individual connection components (provided by Vercel alongside the URLs above)
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=


# -----------------------------------------------------------------------------
# Authentication — Admin Portal
# A single secret shared between you and the server.
# Generate a strong value: openssl rand -base64 32
# Never reuse this value across environments.
# -----------------------------------------------------------------------------

ADMIN_PASSWORD=


# -----------------------------------------------------------------------------
# Cloudinary — Image CDN
# Obtain from: https://console.cloudinary.com → Settings → API Keys
# Signed uploads: the API secret is used server-side to sign upload requests.
# Never expose CLOUDINARY_API_SECRET to the client.
# -----------------------------------------------------------------------------

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=


# -----------------------------------------------------------------------------
# Site
# Used for canonical URLs, Open Graph tags, and sitemap generation.
# Local: http://localhost:3000
# Production: https://your-domain.com (no trailing slash)
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SITE_URL=
